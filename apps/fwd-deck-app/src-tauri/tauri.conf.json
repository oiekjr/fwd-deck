{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fwd Deck",
  "mainBinaryName": "fwd-deck",
  "version": "0.1.3",
  "identifier": "dev.oiekjr.fwddeck",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fwd Deck",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 660
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
